#include "UpCounter.h"

typedef enum {
	RELEASED = 0,
	PUSHED =1
}button_state_t;

void Button_Init()
{

}

button_state_t Button_GetState()
{
	static button_state prevState = RELEASED;
	button_state_t curState = GPIO_ReadPin(GPIOA,GPIO_PIN_4);
	if(prevState == RELEASED && curState == PUSHED){
		prevState = PUSHED;
		return PUSHED;
	}
	else if (prevState == PUSHED && curState == RELEASED){
		prevState = RELEASED;
		return RELEASED;

	}

}

uint16_t counter = 0;

void UpCounter_Init()
{
	FND_Init();
	counter = 0;
}

void UpCounter_Excute()
{
	 UpCounter_DispLoop();

	 if(Button_GetState() == PUSHED)
	 {
		 uint8_t upCounterState = 0;
		 if(upCounterState)
		 {
			 UpCounter_Run();
			 upCounterState = 1;
		 }else {
			 UpCounter_STOP();
		 }


	 }

}

void UpCounter_DispLoop()
{
	FND_DispDigit();
}

void UpCounter_Run()
{
	static uint32_t prevTimeCounter = 0;

	if(millis() - prevTimeCounter < 100-1)
				{
					return;
	}
	prevTimeCounter = millis();

	FND_SetNum(counter++);
}

void UpCounter_Stop()
{
	FND_SetNum(counter++);
}
