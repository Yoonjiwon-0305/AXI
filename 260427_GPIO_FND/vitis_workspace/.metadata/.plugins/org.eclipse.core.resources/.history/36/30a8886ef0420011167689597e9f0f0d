#ifndef SRC_AP_WATCH_WATCH_H_
#define SRC_AP_WATCH_WATCH_H_

#include "../../driver/FND/FND.h"
#include "../../common/common.h"

void Watch_Run()
{
    static uint32_t prevTimeMsec = 0;

    // 1ms마다 msec 증가
    if(millis() - prevTimeMsec < 1) return;
    prevTimeMsec = millis();

    // 밀리초 증가
    watchTime.msec++;
    if(watchTime.msec >= 1000){
        watchTime.msec = 0;

        // 초 증가
        watchTime.sec++;
        if(watchTime.sec >= 60){
            watchTime.sec = 0;

            // 분 증가
            watchTime.min++;
            if(watchTime.min >= 60){
                watchTime.min = 0;

                // 시 증가
                watchTime.hour++;
                if(watchTime.hour >= 24){
                    watchTime.hour = 0;
                }
            }
        }
    }
}

void Watch_Init();
void Watch_Excute();
void Watch_DispLoop();
void Watch_Run();

#endif /* SRC_AP_WATCH_WATCH_H_ */
