#include "UpCounter.h"

uint16_t counter = 0;

void UpCounter_Init()
{
	FND_Init();
	counter = 0;
}

void UpCounter_Excute()
{
	 UpCounter_DispLoop();

	 if(Button_GetState() == PUSHED)
	 {
		 uint8_t upCounterState = 0;
		 if(upCounterState)
		 {
			 UpCounter_Run();
			 upCounterState = 1;
		 }else {
			 UpCounter_STOP();
		 }


	 }

}

void UpCounter_DispLoop()
{
	FND_DispDigit();
}

void UpCounter_Run()
{
	static uint32_t prevTimeCounter = 0;

	if(millis() - prevTimeCounter < 100-1)
				{
					return;
	}
	prevTimeCounter = millis();

	FND_SetNum(counter++);
}

void UpCounter_Stop()
{
	FND_SetNum(counter++);
}
