#include "ap_main.h"
#include "UpCounter/UpCounter.h"
#include "Watch/Watch.h"

typedef enum {
    MODE_UPCOUNTER,
    MODE_WATCH
} app_mode_t;

hBtn_t hBtnMode;

void ap_init()
{
    Button_Init(&hBtnMode, GPIOA, GPIO_PIN_5);
    UpCounter_Init();
    Watch_Init();
}

void ap_excute()   // while(1) 제거
{
    static app_mode_t appMode = MODE_UPCOUNTER;

    // 모드 전환 버튼 체크
    if(Button_GetState(&hBtnMode) == ACT_PUSHED){
        if(appMode == MODE_UPCOUNTER)
            appMode = MODE_WATCH;
        else
            appMode = MODE_UPCOUNTER;
    }

    // 모드에 따라 실행
    switch(appMode)
    {
    case MODE_UPCOUNTER:
        UpCounter_Excute();
        break;
    case MODE_WATCH:
        Watch_Excute();
        break;
    default:
        UpCounter_Excute();
        break;
    }

    millis_inc();
    delay_ms(1);
}
