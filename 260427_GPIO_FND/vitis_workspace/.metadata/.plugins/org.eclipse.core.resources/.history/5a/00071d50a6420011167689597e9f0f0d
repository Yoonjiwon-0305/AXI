void FND_Init()
{
	// GPIO 설정 ,GPIOA0,1,2,3 COM 연결
	GPIO_SetMode(FND_COM_PORT, FND_COM_DIG_1|FND_COM_DIG_2|FND_COM_DIG_3|FND_COM_DIG_4,OUTPUT);
	// GPIO 설정 ,GPIOB seg abcdefg, dp 연결
	GPIO_SetMode(GPIOB, GPIO_PIN_0|GPIO_PIN_1|GPIO_PIN_2|GPIO_PIN_3|GPIO_PIN_4|GPIO_PIN_5|GPIO_PIN_6|GPIO_PIN_7,OUTPUT);
}

