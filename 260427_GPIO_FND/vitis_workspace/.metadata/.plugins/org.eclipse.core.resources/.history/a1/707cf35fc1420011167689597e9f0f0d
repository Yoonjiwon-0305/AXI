#include "UpCounter.h"

uint16_t counter = 0;

void UpCounter_Init()
{
	FND_Init();
	counter = 0;
}

void UpCounter_Excute()
{
		static uint32_t prevTimeCounter = 0;
		FND_DispDigit();

			if(millis() - prevTimeCounter < 100-1)
			{
				return;
			}
			prevTimeCounter = millis();

			FND_SetNum(counter++);

}
