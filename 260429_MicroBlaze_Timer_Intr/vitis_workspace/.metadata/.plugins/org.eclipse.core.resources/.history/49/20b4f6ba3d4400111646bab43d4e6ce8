void FND_SetNum(uint16_t num)
{
	fndNumData = num;
}

#define  FND_DP_ON   	0x00
#define  FND_DP_OFF  	0x80
#define  FND_DIGIT_1 	0x01
#define  FND_DIGIT_10 	0x02
#define  FND_DIGIT_100 	0x04
#define  FND_DIGIT_1000 0x08

FND_DispDP(FND_DIGIT_10,ON);

void FND_DispDP(uint8_t digit, uint8_t on_off)
{
	static uint8_t OnOff;
	OnOff = on_off;

	FND_DispALLOff();
	GPIO_WritePort(FND_FONT_PORT,OnOff<<7);
	FND_SetComPort(FND_COM_PORT,digit,OnOff);
}

void FND_DispALLOn()
{
	FND_SetComPort(FND_COM_PORT,FND_COM_DIG_1|FND_COM_DIG_2|FND_COM_DIG_3|FND_COM_DIG_4,ON);
}

void FND_DispALLOff()
{
	FND_SetComPort(FND_COM_PORT,FND_COM_DIG_1|FND_COM_DIG_2|FND_COM_DIG_3|FND_COM_DIG_4,OFF);
}


