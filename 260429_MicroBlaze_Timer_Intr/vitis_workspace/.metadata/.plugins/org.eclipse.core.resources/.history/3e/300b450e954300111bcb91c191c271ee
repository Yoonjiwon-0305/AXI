#define  INTC_DEV_ID    XPAR_INTC_0_DEVICE_ID
#define  TIMER1_DEV_ID  XPAR_TMR_1_DEVICE_ID
#define  TIMER2_DEV_ID  XPAR_TMR_2_DEVICE_ID


void ap_init()
{
	UpCounter_Init();
}

void ap_excute()
{
	while(1)
	{
		UpCounter_Excute();

		millis_inc();
		delay_ms(1);

	}
}
