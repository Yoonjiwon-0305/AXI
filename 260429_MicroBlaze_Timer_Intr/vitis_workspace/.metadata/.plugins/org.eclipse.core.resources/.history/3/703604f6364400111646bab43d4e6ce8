#include "TimeClock.h"

typedef struct{
	uint8_t hour;
	uint8_t min;
	uint8_t sec;
	uint8_t msec;
}timeClock_t;

timeClock_t timeClock;

void TimeClock_Init()
{

}

void TimeClock_Excute()
{
	TimeClock_DispTime();
}

void TimeClock_IncTime()
{
	timeClock.msec++;
	timeClock.sec++;
	timeClock.min++;
	timeClock.hour++;
}

