#include "LED.h"

static uint8_t ledData =0;

void LED_Init()
{
	// GPIOC 전체 OUTPUT 설정
	GPIO_SetMode(GPIOC, LED_PIN_0|LED_PIN_1|LED_PIN_2|LED_PIN_3|LED_PIN_4|LED_PIN_5|LED_PIN_6|LED_PIN_7, OUTPUT);
	ledData = 0;
	GPIO_WritePort(GPIOC, ledData);
}

void LED_SetPin(uint8_t pin, uint8_t on_off)
{
	// GPIO_WritePin 이용
	if(on_off == LED_ON){
		ledData |= pin;
	} else {
		ledData &= ~pin;
	}
	GPIO_WritePort(GPIOC ,ledData);
}

void LED_WritePort(uint8_t data)
{
	// GPIO_WritePort 이용
	ledData = (ledData & 0xF0) | (data & 0x0F);
	GPIO_WritePort(GPIOC,data);
}

void LED_UpCounter_Excute()
{
    // 상위 4개: PIN7 ON, PIN6 OFF
    // 하위 4개: 0.1초마다 left shift
	LED_SetPin(LED_PIN_7, LED_ON);
	LED_SetPin(LED_PIN_6, LED_OFF);
	LED_SetPin(LED_PIN_5, LED_OFF);
	LED_SetPin(LED_PIN_4, LED_OFF);

}

