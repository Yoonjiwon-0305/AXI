#ifndef SRC_DRIVER_FND_FND_H_
#define SRC_DRIVER_FND_FND_H_

#include <stdint.h>

// Vivado에서 할당된 FND AXI GPIO 주소
#define FND_BASEADDR 0x44A20000

// 12비트 포트 구성: [11:8]은 COM(자릿수), [7:0]은 Segment(데이터)
#define FND_DIGIT_1     0x0100  // COM 1 (bit 8)
#define FND_DIGIT_10    0x0200  // COM 2 (bit 9)
#define FND_DIGIT_100   0x0400  // COM 3 (bit 10)
#define FND_DIGIT_1000  0x0800  // COM 4 (bit 11)

#define ON  0  // Common Anode 기준
#define OFF 1

void FND_Init();
void FND_SetDp(uint8_t digit, uint8_t on_off);
void FND_DispDigit(uint8_t digit_pos, uint8_t num);
void FND_SetNum(uint16_t num);
void FND_DispALLOn();
void FND_DispALLOff();

// FND 갱신용 (TMR 인터럽트 내부에서 호출하기 좋음)
void FND_ISR_Process();

#endif /* SRC_DRIVER_FND_FND_H_ */
