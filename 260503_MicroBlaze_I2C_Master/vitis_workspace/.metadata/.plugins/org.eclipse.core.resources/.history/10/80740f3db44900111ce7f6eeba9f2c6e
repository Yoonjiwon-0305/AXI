#include "ap_main.h"
#include "xil_printf.h"

// HAL 계층 포함
#include "../HAL/GPIO/GPIO.h"
#include "../HAL/I2C/I2C.h"
#include "../HAL/TMR/TMR.h"

// Driver 계층 포함
#include "../driver/FND/FND.h"

#define SLAVE_ADDR 0x12
#define SW_BASEADDR 0x44A00000 // Vivado에서 할당된 AXI_GPIO_SW 주소 (확인 필요)

void ap_init() {
    // 1. 디스플레이 초기화
    FND_Init();

    // 2. I2C 초기화 (내부 레지스터 초기화나 더미 통신 등 필요시)
    // I2C_Init();

    // 3. 딜레이용 타이머 초기화 (옵션: for 루프 대신 TMR을 딜레이용으로 쓴다면)
    TMR_SetPSC(TMR0, 100 - 1); // 1us 단위
    TMR_SetARR(TMR0, 0xffffffff);
    TMR_StopIntr(TMR0);
    TMR_StartTimer(TMR0);

    xil_printf("I2C Master Application Started.\n\r");
}

void ap_excute() {
    uint8_t sw_val = 0;
    uint8_t rx_data = 0;
    uint8_t prev_sw_val = 0xFF; // 변경 감지용 (초기엔 무조건 1회 실행되도록 0xFF 설정)

    while (1) {
        // 1. 스위치 상태 직접 읽기 (Driver 거치지 않음)
        // GPIO_Read 함수는 Xil_In32(SW_BASEADDR) 를 리턴한다고 가정
        sw_val = GPIO_Read(SW_BASEADDR) & 0xFF;

        // 2. 스위치 값이 변했을 때만 통신 (I2C 버스 과부하 방지)
        if (sw_val != prev_sw_val) {

            // SW[7] 값에 따라 분기
            if (sw_val & 0x80) {
                // ==========================================
                // READ 모드: SW[7] == 1
                // ==========================================
                xil_printf("READ Mode: Requesting data...\n\r");

                I2C_Start();
                I2C_Write((SLAVE_ADDR << 1) | 1); // 0x25 전송 (Read 모드)

                // 마지막/단일 바이트를 읽을 때는 NACK(1) 전송
                rx_data = I2C_Read(1);
                I2C_Stop();

                // Slave에서 받아온 데이터를 FND에 출력
                FND_Set_Value(rx_data);
                xil_printf("Received Data: 0x%02X\n\r", rx_data);

            } else {
                // ==========================================
                // WRITE 모드: SW[7] == 0
                // ==========================================
                uint8_t data_to_send = sw_val & 0x7F; // SW[6:0] 값 추출

                xil_printf("WRITE Mode: Sending 0x%02X\n\r", data_to_send);

                I2C_Start();
                I2C_Write((SLAVE_ADDR << 1) | 0); // 0x24 전송 (Write 모드)
                I2C_Write(data_to_send);          // 데이터 전송
                I2C_Stop();

                // 내가 보낸 데이터를 FND에 출력 (디버깅용)
                FND_Set_Value(data_to_send);
            }

            // 이전 상태 업데이트
            prev_sw_val = sw_val;
        }

        // 3. 디바운싱 및 루프 지연 (소프트웨어 딜레이)
        // TMR 딜레이 함수가 있다면 TMR_Delay_ms(10); 등으로 대체 가능
        for (volatile int i = 0; i < 500000; i++);
    }
}
