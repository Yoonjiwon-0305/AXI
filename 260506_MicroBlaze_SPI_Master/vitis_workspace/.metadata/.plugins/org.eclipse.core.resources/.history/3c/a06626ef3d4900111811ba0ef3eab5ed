#include "ap_main.h"
#include "../HAL/GPIO/GPIO.h"
#include "../HAL/SPI/SPI.h"
#include "../driver/Button/Button.h"
#include "../driver/LED/LED.h"
#include "../driver/FND/FND.h"
#include "xil_printf.h"

hBtn_t hBtnSend;

void ap_init() {
    GPIO_SetMode(GPIOA, 0xFF, INPUT);
    GPIO_SetMode(GPIOB, 0xFF, INPUT);
    GPIO_SetMode(GPIOC, 0xFF, OUTPUT);
    GPIO_SetMode(GPIOD, 0xFF, OUTPUT);

    LED_Init();
    FND_Init();

    Button_Init(&hBtnSend, GPIOB, GPIO_PIN_0);
    SPI_Init();
    // TMR ƒ⁄µÂ ¿¸∫Œ ªË¡¶!
}

void ap_excute() {
    uint8_t sw_val;
    uint16_t rx_val=0;

    while (1) {
        FND_DispDigit();

        if (Button_GetState(&hBtnSend) == ACT_PUSHED) {
        	xil_printf("BTN S\n");
            sw_val = GPIO_ReadPort(GPIOA);
            SPI_Transfer(sw_val);
            rx_val = SPI_GetRxData();
            FND_SetNum(rx_val);
        }
    }
}
